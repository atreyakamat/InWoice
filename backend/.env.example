# --- SERVER CONFIG ---
PORT=5000
NODE_ENV=development

# --- AUTHENTICATION ---
ADMIN_PASSWORD=admin123
# For better security, generate a hash and use ADMIN_PASSWORD_HASH instead:
# Generate hash: POST /api/auth/hash-password with {"password": "your-password"}
# ADMIN_PASSWORD_HASH=$2a$10$...

# JWT Configuration
# Generate a random secret: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING_IN_PRODUCTION
JWT_EXPIRES_IN=24h

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=info

# --- AI CONFIG ---
# 1. Ollama AI (Optional)
USE_OLLAMA_AI=false
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen2.5:1.5b

# 2. Local Python AI (Optional)
USE_LOCAL_PYTHON_AI=true
LOCAL_AI_URL=http://127.0.0.1:8000/parse

# 3. Gemini Cloud AI (Optional Fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# --- GOOGLE SHEETS SYNC (Optional) ---
GOOGLE_APPLICATION_CREDENTIALS=credentials.json
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# --- SMTP EMAIL SETTINGS ---
# These can also be configured via the UI in Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
