# ==========================================
# InWoice Backend Configuration
# ==========================================

# Server Configuration
PORT=5000

# ==========================================
# AI Configuration (Choose one or more)
# ==========================================

# Option 1: Local Python AI (Privacy-focused, runs offline)
# Start with: cd local_ai && python main.py
USE_LOCAL_PYTHON_AI=false
LOCAL_AI_URL=http://127.0.0.1:8000/parse

# Option 2: Ollama (Fast local LLM)
# Install from: https://ollama.ai
# Setup: ollama pull qwen2.5:1.5b
USE_OLLAMA_AI=false
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen2.5:1.5b

# Option 3: Google Gemini Cloud AI (Fallback)
# Get API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# Email Configuration (Gmail)
# ==========================================
# 1. Enable 2-Factor Authentication on your Google account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character app password below (no spaces)

EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here

# Email Sender Details (shown in invoices)
SENDER_NAME=Your Business Name
SENDER_EMAIL=your-email@gmail.com

# ==========================================
# Google Sheets Integration (Optional)
# ==========================================
# 1. Create Google Cloud Project
# 2. Enable Google Sheets API
# 3. Create Service Account and download credentials.json
# 4. Place credentials.json in backend/ directory
# 5. Share your spreadsheet with the service account email

GOOGLE_SHEETS_CREDENTIALS_PATH=./credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# ==========================================
# Database Configuration (Optional)
# ==========================================
# Currently using JSON file storage (database.json)
# Future: Add MongoDB/PostgreSQL connection strings here

# ==========================================
# Application Settings
# ==========================================
# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Invoice Settings
INVOICE_PREFIX=INV
INVOICE_STORAGE_PATH=./invoices

# ==========================================
# Security Settings
# ==========================================
# Add JWT secret for future authentication
# JWT_SECRET=your_jwt_secret_here

# Session Secret (if using sessions)
# SESSION_SECRET=your_session_secret_here

# ==========================================
# Development Settings
# ==========================================
NODE_ENV=development
LOG_LEVEL=info

# ==========================================
# Notes
# ==========================================
# - Never commit this file with real credentials
# - Copy this to .env and fill in your actual values
# - Ensure .env is in .gitignore
# - Restart the server after changing environment variables
